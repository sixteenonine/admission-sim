{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "admission-sim",
  "compatibility_date": "2026-05-08",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
  ,
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "admission-sim-db",
      "database_id": "2154b60b-9bf5-4ba1-b0be-8e1c902cd3ab"
    }
  ]
}
